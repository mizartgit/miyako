# Medusa commerce backend (server-side)
MEDUSA_BACKEND_URL=http://localhost:9000

# Publishable key from Medusa Admin → Settings → Publishable API Keys
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# Auth (required — app will not start auth in production without this)
# Generate: openssl rand -base64 32
AUTH_SECRET=dev-local-auth-secret-minimum-32-chars

# PostgreSQL (required for accounts, wishlists, order mirror)
# Can be the same Neon project as Medusa or a separate database
DATABASE_URL=postgresql://user:password@localhost:5432/miyako

# Google Sign-In (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email via Resend (https://resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=MIYAKO <hello@miyako.art>
INQUIRY_EMAIL=hello@miyako.art

# App URL (must match your dev port)
AUTH_URL=http://localhost:3003
