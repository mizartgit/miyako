{
  "name": "@miyako/frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3003",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:verify": "dotenv -e .env.local -- node scripts/verify-auth-db.mjs"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@miyako/shared": "*",
    "@prisma/client": "6.19.3",
    "bcryptjs": "^3.0.3",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.30",
    "next-intl": "^4.13.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "6.19.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
