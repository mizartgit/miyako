// Auth.js + accounts, selections, and future artisan dashboard.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ARTISAN
  ADMIN
}

enum ArtisanStatus {
  PENDING
  APPROVED
  SUSPENDED
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  role          UserRole  @default(CUSTOMER)
  locale        String    @default("en")
  currency      String    @default("JPY")
  emailOptIn    Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  addresses           Address[]
  selections          Selection[]
  artisanProfile      ArtisanProfile?
  notificationPrefs   NotificationPreferences?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Address {
  id         String  @id @default(cuid())
  userId     String
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  label      String?
  line1      String
  line2      String?
  city       String
  region     String?
  postalCode String
  country    String
  isDefault  Boolean @default(false)
}

/// A curated pre-checkout collection ("Selections"). Replaces the old wishlist
/// and the cart: guests keep these in localStorage, signed-in users sync here.
model Selection {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workSlug  String
  variantId String?
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  @@unique([userId, workSlug])
}

model NotificationPreferences {
  id                String  @id @default(cuid())
  userId            String  @unique
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderUpdates       Boolean @default(true)
  shippingUpdates    Boolean @default(true)
  selectionReminders Boolean @default(false)
  marketing          Boolean @default(false)
}

/// Artisan accounts — dashboard not implemented yet.
model ArtisanProfile {
  id              String        @id @default(cuid())
  userId          String        @unique
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug            String        @unique
  status          ArtisanStatus @default(PENDING)
  medusaVendorId String?
  bio             String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  products ArtisanProduct[]
}

model ArtisanProduct {
  id               String         @id @default(cuid())
  artisanProfileId String
  artisanProfile   ArtisanProfile @relation(fields: [artisanProfileId], references: [id], onDelete: Cascade)
  workSlug         String
  medusaProductId String?
  medusaHandle    String?
  inventoryCount   Int            @default(0)
  isPublished      Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([artisanProfileId, workSlug])
}

/// Local order mirror — Medusa remains source of truth for payments.
model OrderMirror {
  id               String      @id @default(cuid())
  userId           String?
  customerEmail    String?
  medusaOrderId    String      @unique
  medusaDisplayId  String?
  status           OrderStatus @default(PENDING)
  totalJpy         Int?
  currency         String      @default("JPY")
  trackingNumber   String?
  trackingUrl      String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}
