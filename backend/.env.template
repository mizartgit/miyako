# Medusa backend — MIYAKO commerce
# Copy to backend/.env and fill in values.

# PostgreSQL (Neon recommended — can share Neon project, use separate DB name)
# Example: postgresql://user:pass@host/miyako_medusa?sslmode=require
DATABASE_URL=

# Redis (required for production/workers; optional for local dev without background jobs)
# Upstash: rediss://default:token@host:6379
REDIS_URL=

# Secrets — generate: openssl rand -base64 32
JWT_SECRET=
COOKIE_SECRET=

# CORS — must include your Next.js frontend URL
STORE_CORS=http://localhost:3003
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:3003,http://localhost:9000

# Public URL of this Medusa server
MEDUSA_BACKEND_URL=http://localhost:9000

# Stripe (Phase 2 — leave empty until ready)
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# Node
NODE_ENV=development
